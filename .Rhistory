stability   |> mutate(source = "monomer"),
interaction |> mutate(source = "complex")
) |>
filter(res_num > 69 & res_num < 147) |>
ggplot(aes(x = res_num, y = all_rel, color = source)) +
geom_line() +
labs(x = "Residue", y = "Relative SASA (%)", color = NULL) +
